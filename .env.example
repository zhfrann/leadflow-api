APP_ENV=development
HTTP_ADDRESS=:8080

HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s

LOG_LEVEL=debug

DATABASE_URL=postgres://leadflow:leadflow_dev_password@localhost:5432/leadflow?sslmode=disable # ?sslmode=disable only for local PostgreSQL
DATABASE_CONNECT_TIMEOUT=5s
DATABASE_HEALTH_TIMEOUT=2s
DATABASE_MAX_CONNS=10

TEST_POSTGRES_DB=leadflow_test
TEST_DATABASE_URL=postgres://leadflow:leadflow_dev_password@localhost:5432/leadflow_test?sslmode=disable

POSTGRES_DB=leadflow
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=leadflow_dev_password
POSTGRES_PORT=5432

REDIS_PORT=6379

MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

MAIL_SMTP_ADDRESS=localhost:1025
MAIL_SMTP_HOST=localhost
MAIL_FROM_NAME=LeadFlow
MAIL_FROM_ADDRESS=no-reply@leadflow.local
MAIL_TIMEOUT=10s

WORKER_POLL_INTERVAL=1s
WORKER_RETRY_DELAYS=10s,30s,2m,10m
WORKER_PROCESSING_TIMEOUT=2m
WORKER_RECOVERY_INTERVAL=30s
